# ── lange-invest environment (copy to .env; NEVER commit .env) ──

# ArcticDB S3 backend (engine). Used by the precompute task and /admin + MCP.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
BUCKET_NAME=
AWS_REGION=

# Web session signing key (humans). Generate: python -c "import secrets;print(secrets.token_urlsafe(48))"
SESSION_SECRET=

# IBKR Flex report ingestion (Phase 3). Private store, never public.
IBKR_FLEX_TOKEN=
IBKR_FLEX_QUERY_ID=

# MCP scoped bearer tokens (Phase 6). Comma-separated NAME:SECRET pairs per scope.
# Treat the admin token like a database root password.
MCP_READ_TOKENS=
MCP_ADMIN_TOKENS=
# Client side: .mcp.json connects Claude Code to POST /mcp with the admin scope
# (full CRUD). Export the SECRET part of an MCP_ADMIN_TOKENS pair as
# LANGE_MCP_ADMIN_TOKEN in the shell where Claude Code runs (not in this file —
# this file configures the server). LANGE_MCP_URL optionally overrides the
# endpoint (e.g. http://localhost:8000/mcp with MCP_ALLOW_INSECURE=1).
# Set to 1 to allow destructive admin-scope ops on protected (IBKR) libraries.
MCP_ALLOW_PROTECTED_OVERRIDE=0

# Optional overrides
# SNAPSHOT_DIR=./data/snapshots
# PRIVATE_DIR=./data/private
